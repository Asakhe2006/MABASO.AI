# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_GOOGLE_CLIENT_ID=
VITE_APPLE_CLIENT_ID=
VITE_APPLE_REDIRECT_URI=

# Core backend
OPENAI_API_KEY=
APP_SECRET=
# Render persistent disk example: mount disk at /data and set this path.
SQLITE_DB_PATH=/data/mabaso_ai.db
ADMIN_EMAILS=
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=

# Billing / PayFast subscriptions
APP_PUBLIC_URL=https://mabaso-ai-web.onrender.com
API_PUBLIC_URL=https://mabaso-ai-api.onrender.com
# PayFast dashboard URLs:
# Return URL: APP_PUBLIC_URL/payment-success
# Cancel URL: APP_PUBLIC_URL/pricing
# Notify URL: API_PUBLIC_URL/api/payfast/webhook
PAYFAST_SANDBOX=true
PAYFAST_SUBSCRIPTION_ENABLED=false
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_REQUIRE_SOURCE_CHECK=false
BILLING_STUDENT_PLUS_AMOUNT_ZAR=49.00
BILLING_PRO_RESEARCH_AMOUNT_ZAR=149.00
FREE_PLAN_STUDY_GUIDES_PER_MONTH=5
FREE_PLAN_QUIZZES_PER_MONTH=5
FREE_PLAN_REPORTS_PER_MONTH=2
FREE_PLAN_MIND_MAPS_PER_MONTH=5
FREE_PLAN_PRESENTATIONS_PER_MONTH=2
FREE_PLAN_PODCASTS_PER_MONTH=2
FREE_PLAN_TEACHER_LESSONS_PER_MONTH=2
FREE_PLAN_STUDY_CHAT_MESSAGES_PER_MONTH=50
FREE_PLAN_VOICE_MESSAGES_PER_MONTH=20
FREE_PLAN_SOURCE_PROCESSING_PER_MONTH=20

# Lecture assistant providers
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_SCHEMA=public
SUPABASE_REQUEST_TIMEOUT_SECONDS=12
GEMINI_CHAT_MODEL=gemini-2.5-flash
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
OPENROUTER_CHAT_MODEL=deepseek/deepseek-chat
OPENROUTER_HTTP_REFERER=https://mabaso-ai-web.onrender.com
OPENROUTER_APP_TITLE=Mabaso AI Lecture Assistant
LECTURE_ASSISTANT_MODEL_TIMEOUT=75
LECTURE_ASSISTANT_MAX_OUTPUT_TOKENS=1200
LECTURE_ASSISTANT_TEXT_MAX_OUTPUT_TOKENS=1200
LECTURE_ASSISTANT_VOICE_MAX_OUTPUT_TOKENS=220
LECTURE_ASSISTANT_VOICE_DETAILED_MAX_OUTPUT_TOKENS=520
LECTURE_ASSISTANT_TITLE_MODEL=gpt-4.1-mini
LECTURE_ASSISTANT_TITLE_TIMEOUT=20
LECTURE_ASSISTANT_TITLE_MAX_WORDS=6
LECTURE_ASSISTANT_SYSTEM_PROMPT=You are a friendly AI assistant that talks naturally like a real person. Keep responses conversational, warm, intelligent, and concise unless detail is needed. Maintain context from previous messages. Avoid robotic wording.
LECTURE_ASSISTANT_TEXT_SYSTEM_PROMPT=You are an advanced academic study assistant inside Mabaso AI. Answer clearly, directly, and accurately. Use markdown and code blocks when they help. Keep simple answers concise, but expand with structured teaching when the student needs detail.
LECTURE_ASSISTANT_VOICE_SYSTEM_PROMPT=You are a real-time conversational voice assistant. Keep spoken responses short, intelligent, conversational, and natural. Answer directly using concise summaries unless the user explicitly asks for detailed explanations. Prioritize low latency, fast responses, natural speech, conversational flow, and token efficiency. Avoid long explanations, excessive formatting, repeating the user's question, and verbose responses. Speak like a human in a real conversation.

# Optional mail / support
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SUPPORT_EMAIL=mabasoasakhe@gmail.com
